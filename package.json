{
  "name": "import-cost-ci",
  "version": "0.4.0",
  "license": "MIT",
  "description": "Know the bundle cost of your imports before CI catches you",
  "type": "module",
  "bin": {
    "import-cost-ci": "dist/index.js"
  },
  "files": [
    "dist/",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "build:action": "esbuild src/index.ts --bundle --platform=node --target=node20 --outfile=dist/action-bundle.cjs --format=cjs --external:esbuild",
    "dev": "node --import tsx/esm src/index.ts",
    "test": "node --import tsx/esm --test test/**/*.test.ts",
    "prepublishOnly": "tsc"
  },
  "dependencies": {
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@rollup/plugin-terser": "^1.0.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "esbuild": "^0.27.5",
    "memfs": "^4.57.1",
    "rollup": "^4.60.1",
    "vite": "^8.0.3",
    "webpack": "^5.105.4"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "c8": "^11.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.4.0"
  }
}
